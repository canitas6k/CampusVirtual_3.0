<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" stylesheets="@../../styles/content.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campusvirtual.controller.student.HistoryController">
    <VBox spacing="15" styleClass="content-area">
        <padding><Insets bottom="25" left="25" right="25" top="25"/></padding>
        <Label text="Historial Académico" styleClass="page-title"/>
        <Label text="Tus entregas y calificaciones" styleClass="page-subtitle"/>
        <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCourse" text="Asignatura" prefWidth="150"/>
                <TableColumn fx:id="colTask" text="Tarea" prefWidth="200"/>
                <TableColumn fx:id="colDate" text="Fecha entrega" prefWidth="120"/>
                <TableColumn fx:id="colGrade" text="Nota" prefWidth="80"/>
                <TableColumn fx:id="colComment" text="Comentario" prefWidth="200"/>
            </columns>
        </TableView>
    </VBox>
</ScrollPane>
