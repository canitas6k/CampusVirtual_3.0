<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" stylesheets="@../../styles/content.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campusvirtual.controller.student.DashboardController">
    <VBox spacing="20" styleClass="content-area">
        <padding><Insets bottom="25" left="25" right="25" top="25"/></padding>

        <Label fx:id="welcomeLabel" styleClass="page-title"/>
        <Label text="Tu resumen del campus" styleClass="page-subtitle"/>

        <HBox spacing="15">
            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="8">
                <Label text="Asignaturas" styleClass="card-title"/>
                <Label fx:id="courseCountLabel" text="0" styleClass="card-value"/>
            </VBox>
            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="8">
                <Label text="Tareas Pendientes" styleClass="card-title"/>
                <Label fx:id="pendingTasksLabel" text="0" styleClass="card-value"/>
            </VBox>
            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="8">
                <Label text="Entregas Realizadas" styleClass="card-title"/>
                <Label fx:id="submissionCountLabel" text="0" styleClass="card-value"/>
            </VBox>
        </HBox>

        <VBox styleClass="card" spacing="10">
            <Label text="Próximas entregas" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <VBox fx:id="upcomingTasksBox" spacing="8"/>
        </VBox>
    </VBox>
</ScrollPane>
