<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" stylesheets="@../../styles/content.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campusvirtual.controller.professor.GradingController">
    <VBox spacing="15" styleClass="content-area">
        <padding><Insets bottom="25" left="25" right="25" top="25"/></padding>
        <Label text="Calificaciones" styleClass="page-title"/>
        <Label text="Entregas pendientes de evaluar" styleClass="page-subtitle"/>
        <TableView fx:id="submissionsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCourse" text="Asignatura" prefWidth="130"/>
                <TableColumn fx:id="colTask" text="Tarea" prefWidth="150"/>
                <TableColumn fx:id="colStudent" text="Alumno" prefWidth="130"/>
                <TableColumn fx:id="colDate" text="Fecha" prefWidth="100"/>
                <TableColumn fx:id="colGradeInput" text="Nota" prefWidth="80"/>
                <TableColumn fx:id="colComment" text="Comentario" prefWidth="150"/>
                <TableColumn fx:id="colAction" text="Acción" prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>
</ScrollPane>
