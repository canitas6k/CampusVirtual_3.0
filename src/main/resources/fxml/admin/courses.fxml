<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" stylesheets="@../../styles/content.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campusvirtual.controller.admin.CourseManagementController">
    <VBox spacing="15" styleClass="content-area">
        <padding><Insets bottom="25" left="25" right="25" top="25"/></padding>
        <Label text="Gestión de Asignaturas" styleClass="page-title"/>

        <!-- Alta de asignatura -->
        <VBox styleClass="card" spacing="12">
            <Label text="Nueva Asignatura" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <HBox spacing="10">
                <TextField fx:id="courseName" promptText="Nombre" styleClass="form-field" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="courseDesc" promptText="Descripción" styleClass="form-field" HBox.hgrow="ALWAYS"/>
                <ChoiceBox fx:id="professorChoice" prefWidth="180"/>
            </HBox>
            <HBox spacing="10">
                <Button fx:id="createCourseBtn" text="Crear Asignatura" styleClass="btn-primary"/>
                <Label fx:id="courseMessage" visible="false"/>
            </HBox>
        </VBox>

        <!-- Tabla de asignaturas -->
        <TableView fx:id="coursesTable" VBox.vgrow="ALWAYS" prefHeight="200">
            <columns>
                <TableColumn fx:id="colCId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colCName" text="Nombre" prefWidth="180"/>
                <TableColumn fx:id="colCDesc" text="Descripción" prefWidth="200"/>
                <TableColumn fx:id="colCProf" text="Profesor" prefWidth="150"/>
                <TableColumn fx:id="colCAction" text="Acción" prefWidth="100"/>
            </columns>
        </TableView>

        <!-- Gestión de matrículas -->
        <VBox styleClass="card" spacing="12">
            <Label text="Inscribir Alumno" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ChoiceBox fx:id="enrollStudent" prefWidth="180"/>
                <ChoiceBox fx:id="enrollCourse" prefWidth="200"/>
                <Button fx:id="enrollBtn" text="Matricular" styleClass="btn-success"/>
                <Label fx:id="enrollMessage" visible="false"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
