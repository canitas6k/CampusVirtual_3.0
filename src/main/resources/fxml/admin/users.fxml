<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" stylesheets="@../../styles/content.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campusvirtual.controller.admin.UserManagementController">
    <VBox spacing="15" styleClass="content-area">
        <padding><Insets bottom="25" left="25" right="25" top="25"/></padding>
        <Label text="Gestión de Usuarios" styleClass="page-title"/>

        <!-- Formulario de alta -->
        <VBox styleClass="card" spacing="12">
            <Label text="Nuevo Usuario" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <HBox spacing="10">
                <TextField fx:id="newUsername" promptText="Usuario" styleClass="form-field" HBox.hgrow="ALWAYS"/>
                <PasswordField fx:id="newPassword" promptText="Contraseña" styleClass="form-field" HBox.hgrow="ALWAYS"/>
            </HBox>
            <HBox spacing="10">
                <TextField fx:id="newFirstName" promptText="Nombre" styleClass="form-field" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="newLastName" promptText="Apellidos" styleClass="form-field" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="newEmail" promptText="Email" styleClass="form-field" HBox.hgrow="ALWAYS"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ChoiceBox fx:id="roleChoice" prefWidth="150"/>
                <Button fx:id="createUserBtn" text="Crear Usuario" styleClass="btn-primary"/>
                <Label fx:id="userMessageLabel" visible="false"/>
            </HBox>
        </VBox>

        <!-- Barra de búsqueda -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Buscar:" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <TextField fx:id="searchField"
                       promptText="Usuario, nombre, email o rol..."
                       styleClass="form-field"
                       HBox.hgrow="ALWAYS"/>
            <Button fx:id="clearSearchBtn" text="✕"
                    style="-fx-background-color: #6B7280; -fx-text-fill: white;
                           -fx-background-radius: 6; -fx-padding: 5 10;
                           -fx-font-size: 13px; -fx-cursor: hand;"/>
        </HBox>

        <!-- Tabla de usuarios -->
        <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colUsername" text="Usuario" prefWidth="100"/>
                <TableColumn fx:id="colName" text="Nombre Completo" prefWidth="160"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="160"/>
                <TableColumn fx:id="colRole" text="Rol" prefWidth="90"/>
                <TableColumn fx:id="colStatus" text="Estado" prefWidth="80"/>
                <TableColumn fx:id="colAction" text="Acción" prefWidth="120"/>
                <TableColumn fx:id="colDelete" text="Eliminar" prefWidth="110"/>
            </columns>
        </TableView>
    </VBox>
</ScrollPane>
