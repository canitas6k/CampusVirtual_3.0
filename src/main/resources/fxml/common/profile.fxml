<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" stylesheets="@../../styles/content.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campusvirtual.controller.ProfileController">
    <VBox spacing="20" styleClass="content-area">
        <padding><Insets bottom="30" left="30" right="30" top="30"/></padding>

        <!-- Cabecera con gradient -->
        <VBox styleClass="profile-header" spacing="4">
            <Label fx:id="nameLabel" styleClass="profile-name"/>
            <Label fx:id="emailLabel" styleClass="profile-email"/>
            <Label fx:id="idLabel" styleClass="profile-id"/>
        </VBox>

        <!-- Formulario de edición -->
        <VBox styleClass="card" spacing="15">
            <Label text="Información Personal" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <HBox spacing="15">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Nombre" styleClass="form-label"/>
                    <TextField fx:id="firstNameField" styleClass="form-field"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Apellidos" styleClass="form-label"/>
                    <TextField fx:id="lastNameField" styleClass="form-field"/>
                </VBox>
            </HBox>

            <HBox spacing="15">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Email" styleClass="form-label"/>
                    <TextField fx:id="emailField" styleClass="form-field"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Titulación" styleClass="form-label"/>
                    <TextField fx:id="degreeField" styleClass="form-field"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Cambio de contraseña -->
        <VBox styleClass="card" spacing="15">
            <Label text="Cambiar Contraseña" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <HBox spacing="15">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Contraseña actual" styleClass="form-label"/>
                    <PasswordField fx:id="currentPasswordField" styleClass="form-field"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Nueva contraseña" styleClass="form-label"/>
                    <PasswordField fx:id="newPasswordField" styleClass="form-field"/>
                </VBox>
            </HBox>
        </VBox>

        <HBox spacing="15">
            <Button fx:id="saveBtn" text="Guardar Cambios" styleClass="btn-primary"/>
            <Label fx:id="messageLabel" visible="false"/>
        </HBox>
    </VBox>
</ScrollPane>
